DATABASE_URL=postgres://relaciona:relaciona@localhost:5433/relaciona?sslmode=disable
DUMP_BASE_URL=https://arquivos.receitafederal.gov.br/index.php/s/YggdBLfdninEJX9
RUST_LOG=relaciona_brasil=debug,info
PORT=8080

# Onde os zips da vintage corrente ficam em disco. Cada subdiretório é uma
# vintage YYYY-MM (~7-10 GB cada). Em produção, vira um volume Docker.
DUMP_DATA_DIR=./data/dumps

# Quantas tasks paralelas o scan dispara (1 por zip). Bom: 4-8.
SCAN_PARALLELISM=4

# Quantas vintages mais recentes manter em disco. Mais antigas são apagadas
# pelo downloader.
KEEP_VINTAGES=2
